<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizdata="sap.viz.ui5.data"
    xmlns:vizfeed="sap.viz.ui5.controls.common.feeds"
    controllerName="sap.dm.custom.plugin.dcchartext.dcchartext.controller.MainView"
    height="100%">
    
    <Page 
        id="dcChartPage"
        showHeader="true"
        title="{i18n>title}">
        
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="Data Collection Chart"/>
                </contentLeft>
                <contentRight>
                    <Select id="chartTypeSelect" change="onChartTypeChange">
                        <items>
                            <core:Item xmlns:core="sap.ui.core" key="line" text="Line"/>
                            <core:Item xmlns:core="sap.ui.core" key="column" text="Column"/>
                            <core:Item xmlns:core="sap.ui.core" key="scatter" text="Scatter"/>
                        </items>
                    </Select>
                    <Button icon="sap-icon://refresh" tooltip="Refresh" press="onRefreshPress"/>
                </contentRight>
            </Bar>
        </customHeader>
        
        <content>
            <VBox width="100%" height="100%">
                
                <!-- Chart -->
                <viz:VizFrame 
                    id="dcVizFrame"
                    width="100%" 
                    height="350px"
                    vizType="line"
                    uiConfig="{applicationSet:'fiori'}">
                    
                    <viz:dataset>
                        <vizdata:FlattenedDataset data="{chartModel>/dataPoints}">
                            <vizdata:dimensions>
                                <vizdata:DimensionDefinition 
                                    name="DateTime" 
                                    value="{chartModel>DateTime}"/>
                            </vizdata:dimensions>
                            <vizdata:measures>
                                <vizdata:MeasureDefinition 
                                    name="Value" 
                                    value="{chartModel>Value}"/>
                            </vizdata:measures>
                        </vizdata:FlattenedDataset>
                    </viz:dataset>
                    
                    <viz:feeds>
                        <vizfeed:FeedItem 
                            uid="valueAxis" 
                            type="Measure" 
                            values="Value"/>
                        <vizfeed:FeedItem 
                            uid="categoryAxis" 
                            type="Dimension" 
                            values="DateTime"/>
                    </viz:feeds>
                    
                </viz:VizFrame>
                
                <!-- Info panel -->
                <Panel 
                    headerText="Parameter: {chartModel>/parameterName}"
                    class="sapUiSmallMarginTop">
                    <content>
                        <Text 
                            text="Select a data collection parameter from the Data Collection List plugin to view values as a chart."
                            visible="{= !${chartModel>/hasData} }"/>
                        <Text 
                            text="Showing {= ${chartModel>/dataPoints}.length } data points"
                            visible="{chartModel>/hasData}"/>
                    </content>
                </Panel>
                
            </VBox>
        </content>
        
    </Page>
    
</mvc:View>