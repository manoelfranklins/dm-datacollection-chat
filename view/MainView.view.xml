<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:vizdata="sap.viz.ui5.data"
    xmlns:vizfeed="sap.viz.ui5.controls.common.feeds"
    xmlns:core="sap.ui.core"
    controllerName="sap.dm.custom.plugin.dcchartext.dcchartext.controller.MainView"
    height="100%">
    
    <Page 
        id="dcChartPage"
        showHeader="true"
        enableScrolling="false">
        
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="Data Collection Chart" />
                </contentLeft>
                <contentRight>
                    <Select id="parameterSelect" 
                            change="onParameterChange"
                            forceSelection="false">
                        <items>
                            <core:Item key="ALL" text="All Parameters"/>
                        </items>
                    </Select>
                    <Select id="chartTypeSelect" change="onChartTypeChange" selectedKey="line">
                        <items>
                            <core:Item key="line" text="Line"/>
                            <core:Item key="column" text="Column"/>
                        </items>
                    </Select>
                    <Button icon="sap-icon://refresh" tooltip="Refresh" press="onRefreshPress"/>
                </contentRight>
            </Bar>
        </customHeader>
        
        <content>
            <viz:VizFrame 
                id="dcVizFrame"
                width="100%" 
                height="400px"
                vizType="line"
                uiConfig="{applicationSet:'fiori'}">
                
                <viz:dataset>
                    <vizdata:FlattenedDataset data="{chartModel>/dataPoints}">
                        <vizdata:dimensions>
                            <vizdata:DimensionDefinition 
                                name="DateTime" 
                                value="{chartModel>DateTime}"/>
                            <vizdata:DimensionDefinition 
                                name="Parameter" 
                                value="{chartModel>ParameterName}"/>
                        </vizdata:dimensions>
                        <vizdata:measures>
                            <vizdata:MeasureDefinition 
                                name="Value" 
                                value="{chartModel>Value}"/>
                        </vizdata:measures>
                    </vizdata:FlattenedDataset>
                </viz:dataset>
                
                <viz:feeds>
                    <vizfeed:FeedItem uid="valueAxis" type="Measure" values="Value"/>
                    <vizfeed:FeedItem uid="categoryAxis" type="Dimension" values="DateTime"/>
                    <vizfeed:FeedItem uid="color" type="Dimension" values="Parameter"/>
                </viz:feeds>
                
            </viz:VizFrame>
        </content>
        
    </Page>
    
</mvc:View>